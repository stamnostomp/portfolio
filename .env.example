# Contact form SMTP settings. Copy to .env next to docker-compose.yml.
# For Proton (Business plan): create an SMTP submission token at
# https://proton.me/support/smtp-submission and use it as SMTP_PASSWORD.
# Proton requires mail to be sent *from* the token's address, so the
# visitor's address is put in Reply-To instead.

SMTP_HOST=smtp.protonmail.ch
SMTP_PORT=587
SMTP_USERNAME=you@yourdomain.com
SMTP_PASSWORD=your-smtp-submission-token

# Where contact messages get delivered / what the From line shows.
# Both default to SMTP_USERNAME when unset.
#CONTACT_TO=you@yourdomain.com
#CONTACT_FROM=you@yourdomain.com
